#!/bin/bash
# zoo-service-restart — 重启所有 Zoo 服务
# 用法: ./zoo-service-restart [daemon|dashboard|all]
# 默认: all（重启全部）

set -e

DAEMON_PORT=18793
DASHBOARD_PORT=18792
PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"

restart_daemon() {
    echo "🔄 重启 daemon (端口 $DAEMON_PORT)..."
    kill $(lsof -t -i :$DAEMON_PORT) 2>/dev/null || true
    sleep 2
    cd "$PROJECT_ROOT"
    FEIDA_ZOO_HOME="$PROJECT_ROOT" 
    nohup /opt/homebrew/bin/python3 framework/core/mesh/zoo_mesh_daemon.py > /tmp/zoo_mesh_daemon.log 2>&1 &
    sleep 3
    if curl -s http://127.0.0.1:$DAEMON_PORT/ > /dev/null 2>&1; then
        echo "✅ daemon 已启动"
    else
        echo "❌ daemon 启动失败"
        return 1
    fi
}

restart_dashboard() {
    echo "🔄 重启 dashboard (端口 $DASHBOARD_PORT)..."
    kill $(lsof -t -i :$DASHBOARD_PORT) 2>/dev/null || true
    sleep 2
    cd "$PROJECT_ROOT"
    FEIDA_ZOO_HOME="$PROJECT_ROOT" nohup /opt/homebrew/bin/python3 dashboard/app_enhanced.py > /tmp/dashboard.log 2>&1 &
    sleep 3
    if curl -s http://127.0.0.1:$DASHBOARD_PORT/ > /dev/null 2>&1; then
        echo "✅ dashboard 已启动"
    else
        echo "❌ dashboard 启动失败"
        return 1
    fi
}

TARGET="${1:-all}"
case "$TARGET" in
    daemon)     restart_daemon ;;
    dashboard)  restart_dashboard ;;
    all)        restart_daemon && restart_dashboard ;;
    *)          echo "用法: $0 [daemon|dashboard|all]"; exit 1 ;;
esac
